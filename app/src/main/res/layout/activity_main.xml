<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- IMAGEN DE FONDO -->
    <ImageView
        android:id="@+id/backgroundImage"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:src="@drawable/bg_neon"
        android:scaleType="centerCrop" />

    <!-- Video de fondo -->
    <VideoView
        android:id="@+id/backgroundVideoView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Overlay oscuro para que el neon resalte -->
    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#80000000" />

    <LinearLayout
        android:layout_width="379dp"
        android:layout_height="606dp"
        android:orientation="vertical"
        android:padding="32dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.175">

        <!-- Título con color Neon Verde -->

        <TextView
            android:id="@+id/mainTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="32dp"
            android:fontFamily="sans-serif-black"
            android:shadowColor="@color/neonPurple"
            android:shadowDx="0"
            android:shadowDy="0"
            android:shadowRadius="20"
            android:text="Baja todo"
            android:textColor="@color/neonGreen"
            android:textSize="42sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginBottom="16dp">

            <Button
                android:id="@+id/historyButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:background="@drawable/rounded_input"
                android:text="@string/btn_history"
                android:textColor="@color/neonGreen"
                android:textSize="14sp"
                app:backgroundTint="@null" />

            <Button
                android:id="@+id/logoutButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:background="@drawable/rounded_input"
                android:text="@string/logout"
                android:textColor="@color/neonPurple"
                android:textSize="14sp"
                app:backgroundTint="@null" />

        </LinearLayout>

        <!-- Nueva caja informativa -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            android:background="@drawable/rounded_input"
            android:gravity="center"
            android:padding="16dp"
            android:text="@string/supported_platforms"
            android:textColor="@color/white"
            android:textSize="16sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/urlInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            android:background="@drawable/rounded_input"
            android:elevation="4dp"
            android:hint="Pega el link de tu video favarito"
            android:inputType="textUri"
            android:padding="16dp"
            android:textColor="@color/white"
            android:textColorHint="@color/hintText" />

        <RadioGroup
            android:id="@+id/modeGroup"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="32dp"
            android:background="@drawable/neon_container"
            android:checkedButton="@+id/videoOption"
            android:orientation="horizontal"
            android:padding="8dp">

            <RadioButton
                android:id="@+id/videoOption"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="16dp"
                android:buttonTint="@color/neonGreen"
                android:text="@string/option_video"
                android:textColor="@color/white" />

            <RadioButton
                android:id="@+id/audioOption"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:buttonTint="@color/neonPurple"
                android:text="@string/option_audio"
                android:textColor="@color/white" />

        </RadioGroup>

        <Button
            android:id="@+id/downloadButton"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:background="@drawable/rounded_button"
            android:elevation="8dp"
            android:text="@string/btn_download"
            android:textColor="@color/white"
            android:textSize="18sp"
            android:textStyle="bold"
            app:backgroundTint="@null" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>